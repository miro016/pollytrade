{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StrategyConfig",
  "type": "object",
  "required": ["name", "parameters", "active", "mode"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string", "maxLength": 100 },
    "description": { "type": "string", "maxLength": 500 },
    "parameters": {
      "type": "object",
      "properties": {
        "indicators": {
          "type": "object",
          "properties": {
            "zscore": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "window": { "type": "integer", "minimum": 5, "maximum": 200 },
                "threshold": { "type": "number", "minimum": 0.5, "maximum": 5.0 },
                "weight": { "type": "number", "minimum": 0, "maximum": 1 }
              }
            },
            "entropy": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "threshold": { "type": "number", "minimum": 0, "maximum": 1 },
                "weight": { "type": "number", "minimum": 0, "maximum": 1 }
              }
            },
            "garch": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "p": { "type": "integer", "minimum": 1, "maximum": 5 },
                "q": { "type": "integer", "minimum": 1, "maximum": 5 },
                "weight": { "type": "number", "minimum": 0, "maximum": 1 }
              }
            },
            "rsi": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "period": { "type": "integer", "minimum": 2, "maximum": 100 },
                "overbought": { "type": "number", "minimum": 50, "maximum": 100 },
                "oversold": { "type": "number", "minimum": 0, "maximum": 50 },
                "weight": { "type": "number", "minimum": 0, "maximum": 1 }
              }
            }
          }
        },
        "min_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "min_edge": { "type": "number", "minimum": 0, "maximum": 0.5 }
      }
    },
    "active": { "type": "boolean" },
    "mode": { "type": "string", "enum": ["paper", "live"] },
    "version": { "type": "integer", "minimum": 1 },
    "created": { "type": "string", "format": "date-time" },
    "updated": { "type": "string", "format": "date-time" }
  }
}
