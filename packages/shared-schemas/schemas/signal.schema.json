{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Signal",
  "type": "object",
  "required": ["market_id", "signal_type", "direction", "value", "confidence"],
  "properties": {
    "id": { "type": "string" },
    "market_id": { "type": "string", "description": "Reference to markets collection" },
    "signal_type": {
      "type": "string",
      "enum": ["zscore", "entropy", "garch", "nash", "ml", "technical", "composite"]
    },
    "direction": { "type": "string", "enum": ["buy", "sell", "hold"] },
    "value": { "type": "number" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Signal-specific data (e.g., z-score value, entropy bits, GARCH forecast)"
    },
    "created": { "type": "string", "format": "date-time" },
    "updated": { "type": "string", "format": "date-time" }
  }
}
