{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Trade",
  "type": "object",
  "required": ["market_id", "side", "amount", "price", "strategy", "mode"],
  "properties": {
    "id": { "type": "string" },
    "market_id": { "type": "string", "description": "Reference to markets collection" },
    "side": { "type": "string", "enum": ["buy", "sell"] },
    "token": { "type": "string", "enum": ["yes", "no"] },
    "amount": { "type": "number", "minimum": 0 },
    "price": { "type": "number", "minimum": 0, "maximum": 1 },
    "strategy": { "type": "string", "maxLength": 100 },
    "mode": { "type": "string", "enum": ["paper", "live"] },
    "pnl": { "type": "number" },
    "fees": { "type": "number", "minimum": 0 },
    "slippage": { "type": "number", "minimum": 0 },
    "signal_id": { "type": "string", "description": "Reference to signals collection" },
    "created": { "type": "string", "format": "date-time" },
    "updated": { "type": "string", "format": "date-time" }
  }
}
